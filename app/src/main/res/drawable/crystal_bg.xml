<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Lavender Background -->
    <item>
        <shape>
            <solid android:color="#E6E6FA"/>
        </shape>
    </item>

    <!-- Large Soft Glow -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerX="0.5"
                android:centerY="0.3"/>
        </shape>
    </item>

    <!-- Sparkle 1 -->
    <item android:left="50dp" android:top="100dp">
        <shape android:shape="oval">
            <size android:width="4dp" android:height="4dp"/>
            <solid android:color="#A0FFFFFF"/>
        </shape>
    </item>

    <!-- Sparkle 2 -->
    <item android:right="80dp" android:top="250dp">
        <shape android:shape="oval">
            <size android:width="3dp" android:height="3dp"/>
            <solid android:color="#80FFFFFF"/>
        </shape>
    </item>

    <!-- Sparkle 3 -->
    <item android:left="150dp" android:bottom="150dp">
        <shape android:shape="oval">
            <size android:width="5dp" android:height="5dp"/>
            <solid android:color="#B0FFFFFF"/>
        </shape>
    </item>

    <!-- Sparkle 4 -->
    <item android:right="40dp" android:bottom="300dp">
        <shape android:shape="oval">
            <size android:width="2dp" android:height="2dp"/>
            <solid android:color="#90FFFFFF"/>
        </shape>
    </item>

    <!-- Bottom Glow -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:startColor="#150095F6"
                android:endColor="#00FFFFFF"
                android:centerX="0.8"
                android:centerY="0.9"/>
        </shape>
    </item>
</layer-list>